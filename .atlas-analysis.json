  "keyFeatures": [
    "Create and manage DeFi Smart Accounts (DSA)",
    "Execute multi-protocol DeFi operations in single transactions",
    "Support for multiple EVM chains (Ethereum, Polygon, Arbitrum, Optimism, etc.)",
    "Browser and Node.js compatibility",
    "Type-safe TypeScript SDK",
    "Composable spell system for complex DeFi workflows"
  ],
  "publicApiSurface": [
    "DSA - Main class for SDK initialization",
    "DSAConfig - Configuration interface for DSA initialization",
    "ChainId - Supported blockchain IDs (1, 137, 42161, 43114, 10, 250, 8453, 9745, 56)",
    "Instance - DSA account instance interface",
    "Spell - Spell class for creating transaction sequences",
    "dsa.build() - Create new DSA account",
    "dsa.getAccounts() - Fetch accounts for an address",
    "dsa.setInstance() - Set active DSA account",
    "dsa.Spell() - Create new spell instance",
    "spell.add() - Add connector method to spell",
    "spell.cast() - Execute spell on blockchain",
    "dsa.encodeSpells() - Encode spells to calldata",
    "dsa.encodeCastABI() - Encode cast ABI",
    "dsa.estimateCastGas() - Estimate gas for spell execution",
    "dsa.erc20 - ERC20 token utilities",
    "dsa.erc721 - ERC721 NFT utilities",
    "dsa.instapool_v2 - Instapool v2 resolver",
    "dsa.avocado - Avocado integration utilities"
  ]
